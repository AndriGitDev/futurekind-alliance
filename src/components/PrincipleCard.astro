---
interface Props { title: string; body: string; index?: number; }
const { title, body, index } = Astro.props;
---
<article class="panel rounded-3xl p-6 transition hover:-translate-y-1 hover:shadow-2xl">
  {typeof index === 'number' && <span class="text-sm font-black text-[#2ba99a]">{String(index + 1).padStart(2, '0')}</span>}
  <h3 class="mt-3 text-xl font-black text-[#14233b]">{title}</h3>
  <p class="mt-3 leading-7 text-[#41515f]">{body}</p>
</article>
