---
interface Props { title: string; body: string; index?: number; }
const { title, body, index } = Astro.props;
---
<article class="panel group rounded-[1.6rem] p-6 transition duration-300 hover:-translate-y-1">
  <div class="flex items-center justify-between gap-4">
    {typeof index === 'number' && <span class="font-mono text-sm font-black text-cyan-200/82">{String(index + 1).padStart(2, '0')}</span>}
    <span class="h-px flex-1 bg-gradient-to-r from-cyan-200/35 to-transparent"></span>
  </div>
  <h3 class="mt-5 text-xl font-black text-cyan-50 group-hover:text-cyan-100">{title}</h3>
  <p class="mt-3 leading-7 text-cyan-50/62">{body}</p>
</article>
