---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
}
const { eyebrow, title, intro } = Astro.props;
---
<section class="relative mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
  <div class="absolute inset-x-4 top-0 h-px bg-gradient-to-r from-transparent via-cyan-200/24 to-transparent"></div>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <div class="mt-4 max-w-4xl">
    <h2 class="text-balance text-4xl font-black tracking-[-0.055em] text-cyan-50 sm:text-6xl">{title}</h2>
    {intro && <p class="mt-5 max-w-3xl text-lg leading-8 text-cyan-50/68">{intro}</p>}
  </div>
  <div class="mt-10"><slot /></div>
</section>
