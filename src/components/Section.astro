---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
}
const { eyebrow, title, intro } = Astro.props;
---
<section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <div class="mt-3 max-w-3xl">
    <h2 class="text-balance text-3xl font-black tracking-tight text-[#14233b] sm:text-5xl">{title}</h2>
    {intro && <p class="mt-5 text-lg leading-8 text-[#41515f]">{intro}</p>}
  </div>
  <div class="mt-10"><slot /></div>
</section>
