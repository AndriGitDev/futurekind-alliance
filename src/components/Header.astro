---
import { navItems, party } from '../data/site';
---
<header class="sticky top-0 z-50 border-b border-cyan-200/15 bg-[#030711]/78 backdrop-blur-2xl supports-[backdrop-filter]:bg-[#030711]/62">
  <nav class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3 sm:px-6 lg:px-8" aria-label="Main navigation">
    <a href="/" class="focus-ring group flex items-center gap-3 rounded-full" aria-label={`${party.name} home`}>
      <span class="relative grid size-11 place-items-center rounded-full border border-cyan-200/30 bg-cyan-200/8 shadow-[0_0_28px_rgba(143,232,226,0.18)] transition group-hover:scale-[1.03]">
        <img src="/assets/alliance-emblem-2040-02.svg" alt="" class="size-10 rounded-full" loading="eager" />
      </span>
      <span class="hidden leading-tight sm:block">
        <strong class="block text-sm uppercase tracking-[0.28em] text-cyan-100">{party.name}</strong>
        <span class="text-xs text-cyan-100/58">{party.ideology} · Civicnet 2040</span>
      </span>
    </a>
    <div class="flex flex-wrap justify-end gap-1 text-[0.68rem] font-bold uppercase tracking-[0.11em] text-cyan-100/72 sm:text-xs lg:tracking-[0.14em]">
      {navItems.map((item) => (
        <a class="focus-ring rounded-full border border-transparent px-3 py-2 transition hover:border-cyan-200/35 hover:bg-cyan-200/10 hover:text-cyan-50 hover:shadow-[0_0_18px_rgba(143,232,226,0.16)]" href={item.href}>{item.label}</a>
      ))}
    </div>
  </nav>
</header>
