---
interface Props { title: string; body: string; index: number; }
const { title, body, index } = Astro.props;
---
<article class="group rounded-3xl border border-[#14233b]/12 bg-white/70 p-6 shadow-sm transition hover:-translate-y-1 hover:bg-[#14233b] hover:text-[#fff8ea] hover:shadow-2xl">
  <div class="flex items-start gap-4">
    <span class="grid size-12 shrink-0 place-items-center rounded-2xl bg-[#f4c95d] font-black text-[#14233b]">{index + 1}</span>
    <div>
      <h3 class="text-xl font-black text-[#14233b] group-hover:text-[#fff8ea]">{title}</h3>
      <p class="mt-3 leading-7 text-[#41515f] group-hover:text-[#fff8ea]/78">{body}</p>
    </div>
  </div>
</article>
