---
import { party } from '../data/site';
---
<footer class="mt-24 border-t border-[#14233b]/10 bg-[#14233b] text-[#fff8ea]">
  <div class="mx-auto grid max-w-7xl gap-8 px-4 py-10 sm:px-6 lg:grid-cols-[1.2fr_0.8fr] lg:px-8">
    <div>
      <p class="eyebrow !text-[#f4c95d]">Fictional civic design</p>
      <p class="mt-3 max-w-3xl text-lg text-[#fff8ea]/86">{party.disclaimer}</p>
    </div>
    <div class="rounded-3xl border border-white/12 bg-white/6 p-5 text-sm text-[#fff8ea]/75">
      <strong class="text-[#fff8ea]">No campaign machinery.</strong>
      <p class="mt-2">No donations, tracking, analytics, voter targeting, mailing-list capture, or real-world party affiliation implied.</p>
    </div>
  </div>
</footer>
