---
import { party } from '../data/site';
---
<footer class="mt-24 border-t border-cyan-200/15 bg-[#02040c]/86 text-cyan-50">
  <div class="mx-auto flex max-w-7xl flex-col gap-4 px-4 py-8 text-sm text-cyan-50/58 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
    <p><strong class="text-cyan-50/80">{party.name}</strong> · Civicnet 2040 · {party.slogan}</p>
    <p class="max-w-2xl lg:text-right">{party.disclaimer}</p>
  </div>
</footer>
