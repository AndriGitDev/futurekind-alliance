---
import { party } from '../data/site';
---
<footer class="mt-24 border-t border-cyan-200/15 bg-[#02040c]/86 text-cyan-50">
  <div class="mx-auto grid max-w-7xl gap-8 px-4 py-10 sm:px-6 lg:grid-cols-[1.2fr_0.8fr] lg:px-8">
    <div>
      <p class="eyebrow">Fictional 2040 civic design</p>
      <p class="mt-3 max-w-3xl text-lg text-cyan-50/68">{party.disclaimer}</p>
    </div>
    <div class="holo-panel rounded-[1.6rem] p-5 text-sm text-cyan-50/68">
      <strong class="text-cyan-50">No campaign machinery.</strong>
      <p class="mt-2">No donations, tracking, analytics, voter targeting, mailing-list capture, or real-world party affiliation implied.</p>
    </div>
  </div>
</footer>
