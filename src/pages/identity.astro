---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
---
<BaseLayout title="Identity" description="Futurekind Alliance public identity assets, emblems, civicnet map, and council credential.">
  <Section
    eyebrow="Public identity register"
    title="Signals people can recognise without turning politics into a flag cult."
    intro="The alliance identity system is meant to feel official, portable, and civic: useful on chapter relays, public credentials, emergency coordination dashboards, meeting notices, and commons infrastructure — not personality merch."
  >
    <div class="grid gap-6 lg:grid-cols-[0.8fr_1.2fr]">
      <article class="dark-panel rounded-[2rem] p-6 sm:p-8">
        <p class="eyebrow">Primary emblem</p>
        <img src="/assets/alliance-emblem.svg" alt="Futurekind Alliance primary emblem" class="mx-auto mt-6 max-w-xs rounded-[2rem] border border-cyan-200/18 shadow-[0_0_46px_rgba(101,247,255,0.2)]" loading="eager" />
        <p class="mt-6 text-cyan-50/70">The star marks personhood and agency. The orbit ring marks federation without a single centre. The small nodes mark municipalities, co-ops, settlements, and habitats joined by rights rather than conquest.</p>
      </article>
      <article class="panel rounded-[2rem] p-6 sm:p-8">
        <p class="eyebrow">Wordmark</p>
        <img src="/assets/alliance-wordmark.svg" alt="Futurekind Alliance wordmark" class="mt-6 w-full rounded-[1.4rem] border border-cyan-200/18" loading="lazy" />
        <div class="mt-6 grid gap-4 md:grid-cols-3">
          <div class="rounded-2xl border border-cyan-200/18 bg-cyan-200/[0.06] p-4"><strong class="text-cyan-50">Cyan</strong><p class="mt-2 text-sm text-cyan-50/62">public reason, transparency, machine accountability</p></div>
          <div class="rounded-2xl border border-lime-200/18 bg-lime-200/[0.06] p-4"><strong class="text-lime-50">Lime</strong><p class="mt-2 text-sm text-lime-50/62">abundance, ecological repair, freedom time</p></div>
          <div class="rounded-2xl border border-violet-200/18 bg-violet-200/[0.06] p-4"><strong class="text-violet-50">Violet</strong><p class="mt-2 text-sm text-violet-50/62">pluralism, distance, habitats, deep futures</p></div>
        </div>
      </article>
    </div>
  </Section>

  <Section eyebrow="Operational imagery" title="Not stock photos. Public records, maps, credentials." intro="A believable 2040 alliance would use many practical visual objects: registry cards, network maps, chapter marks, safety notices, and infrastructure labels.">
    <div class="grid gap-6 lg:grid-cols-2">
      <article class="panel overflow-hidden rounded-[2rem] p-4">
        <div class="mb-4 px-2 pt-2">
          <p class="eyebrow">Civicnet map</p>
          <h2 class="mt-3 text-2xl font-black text-cyan-50">Federation relay graphic</h2>
        </div>
        <img src="/assets/civicnet-map.svg" alt="Futurekind Alliance civicnet federation map" class="w-full rounded-[1.5rem] border border-cyan-200/18" loading="lazy" />
      </article>
      <article class="panel overflow-hidden rounded-[2rem] p-4">
        <div class="mb-4 px-2 pt-2">
          <p class="eyebrow">Council register</p>
          <h2 class="mt-3 text-2xl font-black text-cyan-50">Public credential card</h2>
        </div>
        <img src="/assets/council-credential.svg" alt="Futurekind Alliance Council credential" class="w-full rounded-[1.5rem] border border-cyan-200/18" loading="lazy" />
      </article>
    </div>
  </Section>
</BaseLayout>
