---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import { allianceModel } from '../data/site';
---
<BaseLayout title="Federation" description="How the fictional 2040 Futurekind Alliance federates communities, colonies, and commons.">
  <Section eyebrow="Federation" title="An alliance, not a centre of command." intro="Futurekind Alliance is imagined as a 2040 transnational formation: local autonomy, shared rights, common infrastructure, and peaceful exit.">
    <div class="grid gap-6 lg:grid-cols-2">
      <article class="panel rounded-[2rem] p-6">
        <h2 class="text-2xl font-black text-[#14233b]">Member communities</h2>
        <ul class="mt-5 space-y-3">
          {allianceModel.members.map((member) => <li class="rounded-2xl bg-white/70 p-4 font-semibold text-[#14233b]">{member}</li>)}
        </ul>
      </article>
      <article class="dark-panel rounded-[2rem] p-6">
        <h2 class="text-2xl font-black">2040 promise</h2>
        <p class="mt-5 text-lg leading-8 text-[#fff8ea]/82">Colonies in this setting are consensual self-governing settlements and habitats — not extraction zones. The alliance exists to prevent company towns, machine rule, border precarity, and local majorities from becoming new forms of domination.</p>
      </article>
      <article class="panel rounded-[2rem] p-6 lg:col-span-2">
        <h2 class="text-2xl font-black text-[#14233b]">Constitutional layers</h2>
        <div class="mt-5 grid gap-5 md:grid-cols-2">
          {allianceModel.constitutionalLayers.map((layer) => <div class="rounded-3xl bg-white/70 p-5"><strong class="text-[#14233b]">{layer.title}</strong><p class="mt-3 text-[#41515f]">{layer.body}</p></div>)}
        </div>
      </article>
      <article class="panel rounded-[2rem] p-6 lg:col-span-2">
        <h2 class="text-2xl font-black text-[#14233b]">Slogan studies</h2>
        <div class="mt-5 grid gap-3 md:grid-cols-2">
          {allianceModel.slogans.map((slogan) => <p class="rounded-2xl bg-white/70 p-4 font-semibold text-[#14233b]">“{slogan}”</p>)}
        </div>
      </article>
    </div>
  </Section>
</BaseLayout>
