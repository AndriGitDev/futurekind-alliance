---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import { allianceModel } from '../data/site';
---
<BaseLayout title="Federation" description="How the fictional 2040 Futurekind Alliance federates communities, colonies, and commons.">
  <Section eyebrow="Federation" title="An alliance, not a centre of command." intro="Futurekind Alliance is imagined as a 2040 transnational formation: local autonomy, shared rights, common infrastructure, and peaceful exit.">
    <div class="grid gap-6 lg:grid-cols-2">
      <article class="panel rounded-[2rem] p-6">
        <h2 class="text-2xl font-black text-cyan-50">Member communities</h2>
        <ul class="mt-5 space-y-3">
          {allianceModel.members.map((member) => <li class="rounded-2xl border border-cyan-200/18 bg-cyan-200/[0.055] p-4 font-semibold text-cyan-50/78">{member}</li>)}
        </ul>
      </article>
      <article class="dark-panel rounded-[2rem] p-6">
        <h2 class="text-2xl font-black text-cyan-50">2040 promise</h2>
        <p class="mt-5 text-lg leading-8 text-cyan-50/72">Colonies in this setting are consensual self-governing settlements and habitats — not extraction zones. The alliance exists to prevent company towns, machine rule, border precarity, and local majorities from becoming new forms of domination.</p>
      </article>
      <article class="panel overflow-hidden rounded-[2rem] p-4 lg:col-span-2">
        <div class="mb-4 flex flex-wrap items-center justify-between gap-3 px-2 pt-2">
          <h2 class="text-2xl font-black text-cyan-50">Civicnet federation relay</h2>
          <span class="text-xs font-black uppercase tracking-[0.22em] text-cyan-100/56">public map · 2040.11.03</span>
        </div>
        <img src="/assets/civicnet-map.svg?v=fka-identity-2040-02" alt="Stylised Futurekind Alliance civicnet federation map" class="w-full rounded-[1.5rem] border border-cyan-200/18" loading="lazy" />
      </article>
      <article class="panel rounded-[2rem] p-6 lg:col-span-2">
        <h2 class="text-2xl font-black text-cyan-50">Constitutional layers</h2>
        <div class="mt-5 grid gap-5 md:grid-cols-2">
          {allianceModel.constitutionalLayers.map((layer) => <div class="rounded-3xl border border-violet-200/20 bg-violet-200/[0.055] p-5"><strong class="text-violet-50">{layer.title}</strong><p class="mt-3 text-cyan-50/62">{layer.body}</p></div>)}
        </div>
      </article>
      <article class="panel rounded-[2rem] p-6 lg:col-span-2">
        <h2 class="text-2xl font-black text-cyan-50">Slogan studies</h2>
        <div class="mt-5 grid gap-3 md:grid-cols-2">
          {allianceModel.slogans.map((slogan) => <p class="rounded-2xl border border-lime-200/20 bg-lime-200/[0.07] p-4 font-semibold text-lime-50">“{slogan}”</p>)}
        </div>
      </article>
    </div>
  </Section>
</BaseLayout>
