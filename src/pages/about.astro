---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import { party } from '../data/site';
---
<BaseLayout title="About" description="About and disclaimer for this fictional 2040 political design project.">
  <Section eyebrow="About" title="This is a fictional 2040 party-site, not a campaign." intro="The site explores how an international political alliance might communicate Freedom Commons Federalism clearly and responsibly in 2040.">
    <div class="grid gap-6 lg:grid-cols-[1fr_0.8fr]">
      <article class="panel rounded-[2rem] p-6 text-lg leading-8 text-cyan-50/68 sm:p-10">
        <p><strong class="text-cyan-50">{party.name}</strong> is a fictional/speculative political alliance concept set in 2040. It is not registered, not soliciting votes, not raising funds, and not operating as a real electoral organisation.</p>
        <p class="mt-5">The purpose is civic imagination: testing whether a philosophy centred on anti-domination, universal rights, cooperative abundance, public-interest technology, democratic federation, and consensual self-governing colonies can be explained without falling into authoritarian aesthetics, corporate blandness, or left/right cliché.</p>
        <p class="mt-5">The site intentionally excludes donation flows, analytics, mailing-list capture, voter profiling, tracking pixels, manipulative urgency patterns, and real political party branding.</p>
      </article>
      <aside class="dark-panel rounded-[2rem] p-6">
        <p class="eyebrow">Design constraints</p>
        <ul class="mt-5 space-y-4 text-cyan-50/72">
          <li>✓ 2040 civic futurism + democratic seriousness</li>
          <li>✓ International federation + local autonomy</li>
          <li>✓ Science-fiction dignity, no derivative branding</li>
          <li>✓ Colonies as consensual communities, never imperial extraction</li>
          <li>✕ No donations or voter targeting</li>
          <li>✕ No Star Trek logos or copyrighted marks</li>
          <li>✕ No authoritarian black/red militarism</li>
        </ul>
      </aside>
    </div>
  </Section>
</BaseLayout>
