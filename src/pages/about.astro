---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import { party } from '../data/site';
---
<BaseLayout title="About" description="About the 2040 Futurekind Alliance, its federation model, and publication note.">
  <Section eyebrow="About" title="A federation built to make freedom practical." intro="Futurekind Alliance began as a compact between municipalities, cooperatives, adaptation settlements, rights networks, and remote research habitats that needed shared infrastructure without a new centre of domination.">
    <div class="grid gap-6 lg:grid-cols-[1fr_0.8fr]">
      <article class="panel rounded-[2rem] p-6 text-lg leading-8 text-cyan-50/68 sm:p-10">
        <p><strong class="text-cyan-50">{party.name}</strong> works from a simple premise: freedom is not real when survival depends on obedience to a boss, landlord, border regime, machine, platform, local majority, or distant bureaucracy.</p>
        <p class="mt-5">The alliance federates local communities around universal personhood rights, cooperative infrastructure, public-interest AI, mobility, peaceful exit, and democratic control over the commons that make a dignified life possible.</p>
        <p class="mt-5">Its members keep their languages, institutions, cultures, and experiments. They share the guarantees no community may break: due process, exit, non-domination, ecological responsibility, and rights that do not depend on passport, productivity, or origin.</p>
      </article>
      <aside class="dark-panel rounded-[2rem] p-6">
        <p class="eyebrow">Publication note</p>
        <p class="mt-5 text-cyan-50/72">Speculative civic fiction from a possible 2040. Not a registered organisation, electoral campaign, or fundraising vehicle.</p>
        <ul class="mt-6 space-y-4 text-cyan-50/72">
          <li>✓ International federation + local autonomy</li>
          <li>✓ Colonies as consensual self-governing habitats</li>
          <li>✓ Public-interest technology, never machine rule</li>
          <li>✕ No donations, tracking, or voter targeting</li>
        </ul>
      </aside>
    </div>
  </Section>
</BaseLayout>
