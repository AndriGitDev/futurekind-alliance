---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import PrincipleCard from '../components/PrincipleCard.astro';
import PolicyCard from '../components/PolicyCard.astro';
import { party, principles, policies } from '../data/site';
---
<BaseLayout description={party.shortLine}>
  <Hero />
  <Section eyebrow="Signal brief" title="A 2040 alliance for real freedom." intro="Futurekind Alliance imagines an international federation where survival is not conditional on obedience, civic colonies are self-governing rather than imperial, technology reduces toil instead of concentrating power, and democracy remains legible enough for citizens to control.">
    <div class="grid gap-4 md:grid-cols-3">
      <div class="holo-panel rounded-[1.7rem] p-6 text-cyan-50"><strong class="text-2xl font-black">Maximum freedom</strong><p class="mt-3 text-cyan-50/66">Not merely fewer rules, but fewer masters: no domination by poverty, monopoly, borders, bureaucracy, violence, platforms, colonies, or machines.</p></div>
      <div class="rounded-[1.7rem] border border-lime-200/30 bg-lime-200/12 p-6 text-lime-50 shadow-[0_0_34px_rgba(200,255,106,0.12)]"><strong class="text-2xl font-black">Shared abundance</strong><p class="mt-3 text-lime-50/70">Cooperative automation, public-interest infrastructure, and commons trusts turn productivity into freedom time and universal security.</p></div>
      <div class="rounded-[1.7rem] border border-violet-200/30 bg-violet-200/12 p-6 text-violet-50 shadow-[0_0_34px_rgba(155,124,255,0.12)]"><strong class="text-2xl font-black">Federated worlds</strong><p class="mt-3 text-violet-50/70">Cities, habitats, settlements, and cooperatives stay locally rooted while sharing rights, infrastructure, and peaceful exit.</p></div>
    </div>
  </Section>
  <Section eyebrow="Principles" title="Rules of thumb for a non-dominating future." intro="Short enough to scan, demanding enough to shape institutions across borders and colonies.">
    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {principles.slice(0, 6).map((principle, index) => <PrincipleCard {...principle} index={index} />)}
    </div>
  </Section>
  <Section eyebrow="Policy pillars" title="Ten starting points, not a finished constitution." intro="Each pillar converts the philosophy into a design question for law, infrastructure, member communities, and public institutions.">
    <div class="grid gap-5 lg:grid-cols-2">
      {policies.slice(0, 4).map((policy, index) => <PolicyCard {...policy} index={index} />)}
    </div>
  </Section>
</BaseLayout>
