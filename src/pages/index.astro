---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import PrincipleCard from '../components/PrincipleCard.astro';
import PolicyCard from '../components/PolicyCard.astro';
import { party, principles, policies } from '../data/site';
---
<BaseLayout description={party.shortLine}>
  <Hero />
  <Section eyebrow="The one-minute version" title="A party-shaped thought experiment for real freedom." intro="The Commons Future Party imagines a society where survival is not conditional on obedience, technology reduces toil instead of concentrating power, and democracy remains legible enough for citizens to control.">
    <div class="grid gap-4 md:grid-cols-3">
      <div class="rounded-3xl bg-[#14233b] p-6 text-[#fff8ea]"><strong class="text-xl">Maximum freedom</strong><p class="mt-3 text-[#fff8ea]/75">Not merely fewer rules, but fewer masters: no domination by poverty, monopoly, borders, bureaucracy, violence, platforms, or machines.</p></div>
      <div class="rounded-3xl bg-[#2ba99a] p-6 text-[#082822]"><strong class="text-xl">Shared abundance</strong><p class="mt-3 text-[#082822]/75">Cooperative automation, public-interest infrastructure, and commons trusts turn productivity into freedom time and universal security.</p></div>
      <div class="rounded-3xl bg-[#f4c95d] p-6 text-[#14233b]"><strong class="text-xl">No domination</strong><p class="mt-3 text-[#14233b]/75">Every institution must remain accountable, appealable, forkable, and bound by rights.</p></div>
    </div>
  </Section>
  <Section eyebrow="Principles" title="Rules of thumb for a non-dominating future." intro="Short enough to scan, demanding enough to shape institutions.">
    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {principles.slice(0, 6).map((principle, index) => <PrincipleCard {...principle} index={index} />)}
    </div>
  </Section>
  <Section eyebrow="Policy pillars" title="Ten starting points, not a finished constitution." intro="Each pillar converts the philosophy into a design question for law, infrastructure, and public institutions.">
    <div class="grid gap-5 lg:grid-cols-2">
      {policies.slice(0, 4).map((policy, index) => <PolicyCard {...policy} index={index} />)}
    </div>
  </Section>
</BaseLayout>
