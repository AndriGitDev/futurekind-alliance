---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import { labIdeas } from '../data/site';
---
<BaseLayout title="Party Lab" description="Naming, palette, logo, and messaging lab for the fictional party.">
  <Section eyebrow="Party Lab" title="A place to test names, symbols, slogans, and tone." intro="The project is built so the identity can evolve without rewriting the underlying philosophy.">
    <div class="grid gap-6 lg:grid-cols-2">
      <article class="panel rounded-[2rem] p-6"><h2 class="text-2xl font-black text-[#14233b]">Name candidates</h2><ul class="mt-5 space-y-3">{labIdeas.names.map((name) => <li class="rounded-2xl bg-white/70 p-4 font-semibold text-[#14233b]">{name}</li>)}</ul></article>
      <article class="panel rounded-[2rem] p-6"><h2 class="text-2xl font-black text-[#14233b]">Slogan variants</h2><ul class="mt-5 space-y-3">{labIdeas.slogans.map((slogan) => <li class="rounded-2xl bg-white/70 p-4 font-semibold text-[#14233b]">“{slogan}”</li>)}</ul></article>
      <article class="panel rounded-[2rem] p-6 lg:col-span-2"><h2 class="text-2xl font-black text-[#14233b]">Palette studies</h2><div class="mt-5 grid gap-5 md:grid-cols-3">{labIdeas.palettes.map((palette) => <div class="rounded-3xl bg-white/70 p-4"><strong>{palette.name}</strong><div class="mt-4 flex overflow-hidden rounded-2xl">{palette.swatches.map((swatch) => <span class="h-16 flex-1" style={`background:${swatch}`} title={swatch}></span>)}</div></div>)}</div></article>
      <article class="dark-panel rounded-[2rem] p-6 lg:col-span-2"><h2 class="text-2xl font-black">Logo directions</h2><div class="mt-5 grid gap-4 md:grid-cols-2">{labIdeas.logoDirections.map((idea) => <p class="rounded-2xl bg-white/10 p-5 text-[#fff8ea]/82">{idea}</p>)}</div></article>
    </div>
  </Section>
</BaseLayout>
