---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { party } from '../data/site';
import '../styles/global.css';

interface Props { title?: string; description?: string; }
const siteTitle = party.name;
const { title = siteTitle, description = party.shortLine } = Astro.props;
const pageTitle = title === siteTitle ? title : `${title} · ${siteTitle}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noarchive" />
    <link rel="icon" type="image/svg+xml" href="/favicon-2040-02.svg" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="shell min-h-screen">
      <Header />
      <main><slot /></main>
      <Footer />
    </div>
    <script>
      // Mobile-first reliability layer for internal navigation. A few Android
      // Chromium/Samsung Browser builds can treat visually rich links as a
      // hover target and fail to complete native anchor navigation. Keep the
      // actual routing deliberately boring: any tap/click/touch ending on an
      // internal link assigns the URL directly.
      (() => {
        const getAnchor = (target: EventTarget | null): HTMLAnchorElement | null => {
          if (!target) return null;
          const node = target instanceof Node && target.nodeType === Node.TEXT_NODE ? target.parentElement : target;
          return node instanceof Element ? node.closest<HTMLAnchorElement>('a[href]') : null;
        };

        const go = (event: MouseEvent | PointerEvent | TouchEvent) => {
          if (event.defaultPrevented) return;
          if ('button' in event && event.button > 0) return;
          if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;

          const anchor = getAnchor(event.target);
          if (!anchor || anchor.target || anchor.hasAttribute('download')) return;

          const url = new URL(anchor.href, window.location.href);
          if (url.origin !== window.location.origin || url.href === window.location.href) return;

          event.preventDefault();
          window.location.href = url.href;
        };

        document.addEventListener('touchend', go, { capture: true, passive: false });
        document.addEventListener('pointerup', go, { capture: true });
        document.addEventListener('click', go, { capture: true });
      })();
    </script>
  </body>
</html>
