---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { party } from '../data/site';
import '../styles/global.css';

interface Props { title?: string; description?: string; }
const siteTitle = party.name;
const { title = siteTitle, description = party.shortLine } = Astro.props;
const pageTitle = title === siteTitle ? title : `${title} · ${siteTitle}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noarchive" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="shell min-h-screen">
      <Header />
      <main><slot /></main>
      <Footer />
    </div>
    <script>
      // Some mobile in-app browsers can swallow the first tap on heavily styled
      // hoverable links. Keep navigation boring and explicit for all internal
      // site links: pointer-up/click goes straight to the target URL.
      (() => {
        const navigate = (event: MouseEvent | PointerEvent) => {
          if (event.defaultPrevented || event.button > 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
          if (!(event.target instanceof Element)) return;
          const anchor = event.target.closest('a[href]') as HTMLAnchorElement | null;
          if (!anchor || anchor.target || anchor.hasAttribute('download')) return;
          const url = new URL(anchor.href, window.location.href);
          if (url.origin !== window.location.origin || url.href === window.location.href) return;
          event.preventDefault();
          window.location.assign(url.href);
        };
        document.addEventListener('pointerup', navigate, { capture: true });
        document.addEventListener('click', navigate, { capture: true });
      })();
    </script>
  </body>
</html>
